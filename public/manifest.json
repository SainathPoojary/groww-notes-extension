{
    "manifest_version": 3,
    "name": "Groww Notes",
    "version": "1.0.0",
    "description": "Add quick notes for any stocks",
    "action":{
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://groww.in/stocks/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}